# Root-level .env.example – used by docker-compose.
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- Backend settings (also used by backend/.env) ---

# SQLite (default) or PostgreSQL for production:
DATABASE_URL=sqlite:///./negotiator.db

# IMPORTANT: generate a strong random key before deploying to production.
# Example (Linux/macOS): python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
